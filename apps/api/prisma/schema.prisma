generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== UTILISATEURS =====

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  restaurant   String?   // nom du restaurant
  phone        String?
  isActive     Boolean   @default(true)
  plan         String    @default("free") // "free" | "pro"
  createdAt    DateTime  @default(now())

  ingredients  Ingredient[]
  recipes      Recipe[]
  invoices     Invoice[]
}

// ===== INGREDIENTS =====

model Ingredient {
  id           Int            @id @default(autoincrement())
  userId       Int
  user         User           @relation(fields: [userId], references: [id])
  name         String         // "Beurre", "Saumon", "Farine"
  unit         String         // "kg", "L", "pièce", "g"
  currentPrice Decimal        @default(0) // prix actuel par unité
  category     String?        // "viande", "poisson", "légume", "épice"...
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  recipeItems  RecipeItem[]
  priceHistory PriceHistory[]
  invoiceItems InvoiceItem[]
}

// ===== HISTORIQUE DES PRIX =====

model PriceHistory {
  id           Int        @id @default(autoincrement())
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  price        Decimal    // prix à cette date
  source       String     // "manual" | "invoice"
  recordedAt   DateTime   @default(now())
}

// ===== RECETTES =====

model Recipe {
  id           Int          @id @default(autoincrement())
  userId       Int
  user         User         @relation(fields: [userId], references: [id])
  name         String       // "Filet de saumon", "Burger maison"
  category     String?      // "entrée", "plat", "dessert"
  sellingPrice Decimal      // prix de vente TTC
  vatRate      Decimal      @default(0.10) // TVA (10% par défaut)
  isActive     Boolean      @default(true)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  items        RecipeItem[]
}

// ===== INGREDIENTS D'UNE RECETTE =====

model RecipeItem {
  id           Int        @id @default(autoincrement())
  recipeId     Int
  recipe       Recipe     @relation(fields: [recipeId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Decimal    // quantité en unité de l'ingrédient (ex: 0.200 kg)
  notes        String?    // "pour la sauce", "garniture"
}

// ===== FACTURES =====

model Invoice {
  id             Int           @id @default(autoincrement())
  userId         Int
  user           User          @relation(fields: [userId], references: [id])
  supplierName   String?       // "Metro", "Transgourmet", "Bio Primeur"
  invoiceDate    DateTime?     // date de la facture
  totalAmount    Decimal?      // montant total de la facture
  fileUrl        String?       // chemin vers le fichier uploadé
  fileType       String?       // "pdf" | "image"
  status         String        @default("pending")
  // "pending"   → uploadée, en attente d'analyse
  // "analyzing" → en cours d'analyse par l'IA
  // "reviewed"  → analysée, en attente de validation
  // "validated" → validée par l'utilisateur
  // "error"     → erreur lors de l'analyse
  rawAiResponse  String?       // réponse brute de l'IA (pour debug)
  createdAt      DateTime      @default(now())

  items          InvoiceItem[]
}

// ===== LIGNES D'UNE FACTURE =====

model InvoiceItem {
  id             Int         @id @default(autoincrement())
  invoiceId      Int
  invoice        Invoice     @relation(fields: [invoiceId], references: [id])
  ingredientId   Int?        // null si l'IA n'a pas reconnu l'ingrédient
  ingredient     Ingredient? @relation(fields: [ingredientId], references: [id])
  rawName        String      // nom brut lu sur la facture "BEURRE DOUX 1KG"
  quantity       Decimal?    // quantité sur la facture
  unit           String?     // unité sur la facture
  unitPrice      Decimal?    // prix unitaire extrait
  totalPrice     Decimal?    // prix total de la ligne
  isConfirmed    Boolean     @default(false) // validé par l'utilisateur
  matchScore     Float?      // score de similarité 0-1
  matchMethod    String?     // "auto" | "suggestion" | "memory" | "none"
}

// ===== MÉMOIRE DES CORRESPONDANCES FACTURES =====

model InvoiceMatchMemory {
  id           Int      @id @default(autoincrement())
  userId       Int
  rawName      String
  ingredientId Int
  confirmedAt  DateTime @default(now())

  @@unique([userId, rawName])
}